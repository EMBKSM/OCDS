      "rangeLength": 0,
      "text": "/******************************************************************************\r\n * Cloud Detection Accelerator Main Application\r\n * Target: Zynq UltraScale+ MPSoC (ZCU102)\r\n * IP: HLS Cloud MLP + AXI DMA (Simple Mode)\r\n ******************************************************************************/\r\n\r\n#include <stdio.h>\r\n#include \"platform.h\"\r\n#include \"xil_printf.h\"\r\n#include \"xparameters.h\"\r\n#include \"xaxidma.h\"\r\n#include \"xil_cache.h\"\r\n\r\n// ----------------------------------------------------------------------------\r\n// [중요] HLS IP 헤더 파일 포함\r\n// Vitis 왼쪽 탐색기의 Includes -> bsp -> include 폴더에 있는 파일명을 확인하세요.\r\n// 보통 \"x\" + \"IP이름\" + \".h\" 입니다.\r\n// ----------------------------------------------------------------------------\r\n#include \"xcloud_mlp_top.h\" \r\n\r\n// ----------------------------------------------------------------------------\r\n// 하드웨어 ID 정의 (xparameters.h 참조)\r\n// ----------------------------------------------------------------------------\r\n#define DMA_DEV_ID          XPAR_AXI_DMA_0_DEVICE_ID\r\n#define HLS_MLP_DEV_ID      XPAR_CLOUD_MLP_TOP_0_DEVICE_ID\r\n\r\n// ----------------------------------------------------------------------------\r\n// 데이터 사이즈 정의 (★ 사용자 모델에 맞게 수정 필수 ★)\r\n// 예: 입력이 32x32 이미지(1024개), 출력이 구름/비구름 확률(2개)인 경우\r\n// ----------------------------------------------------------------------------\r\n#define INPUT_LENGTH        (1024)          // 입력 데이터 개수 (예: 1024 floats)\r\n#define OUTPUT_LENGTH       (2)             // 출력 데이터 개수 (예: 2 floats)\r\n\r\n// 바이트 단위 크기 계산\r\n#define INPUT_SIZE_BYTES    (INPUT_LENGTH * sizeof(float))\r\n#define OUTPUT_SIZE_BYTES   (OUTPUT_LENGTH * sizeof(float))\r\n\r\n// ----------------------------------------------------------------------------\r\n// 메모리 버퍼 (DDR에 할당)\r\n// 캐시 일관성(Cache Coherency)을 위해 64바이트 정렬 필수\r\n// ----------------------------------------------------------------------------\r\nfloat InputBuffer[INPUT_LENGTH]   __attribute__ ((aligned (64)));\r\nfloat OutputBuffer[OUTPUT_LENGTH] __attribute__ ((aligned (64)));\r\n\r\n// 드라이버 인스턴스 전역 변수\r\nXAxiDma DmaInstance;\r\nXCloud_mlp_top HlsInstance;\r\n\r\nint main()\r\n{\r\n    int Status;\r\n\r\n    init_platform();\r\n    print(\"\\r\\n=================================================\\r\\n\");\r\n    print(\"   Cloud Detection AI Hardware Accelerator Start\\r\\n\");\r\n    print(\"=================================================\\r\\n\");\r\n\r\n    // =========================================================================\r\n    // 1. 하드웨어 초기화 (Initialization)\r\n    // =========================================================================\r\n    \r\n    // [1-1] HLS IP 초기화\r\n    XCloud_mlp_top_Config *HlsConfig = XCloud_mlp_top_LookupConfig(HLS_MLP_DEV_ID);\r\n    if (!HlsConfig) {\r\n        print(\"Error: HLS Config not found.\\r\\n\");\r\n        return XST_FAILURE;\r\n    }\r\n\r\n    Status = XCloud_mlp_top_CfgInitialize(&HlsInstance, HlsConfig);\r\n    if (Status != XST_SUCCESS) {\r\n        print(\"Error: HLS Initialization failed.\\r\\n\");\r\n        return XST_FAILURE;\r\n    }\r\n\r\n    // [1-2] DMA 초기화\r\n    XAxiDma_Config *DmaConfig = XAxiDma_LookupConfig(DMA_DEV_ID);\r\n    if (!DmaConfig) {\r\n        print(\"Error: DMA Config not found.\\r\\n\");\r\n        return XST_FAILURE;\r\n    }\r\n\r\n    Status = XAxiDma_CfgInitialize(&DmaInstance, DmaConfig);\r\n    if (Status != XST_SUCCESS) {\r\n        print(\"Error: DMA Initialization failed.\\r\\n\");\r\n        return XST_FAILURE;\r\n    }\r\n\r\n    // DMA Scatter-Gather 모드 체크 (우리는 껐으므로 있으면 에러)\r\n    if (XAxiDma_HasSg(&DmaInstance)) {\r\n        print(\"Error: DMA configured as SG mode. Please use Simple mode.\\r\\n\");\r\n        return XST_FAILURE;\r\n    }\r\n\r\n    // 인터럽트 끄기 (Polling 모드 사용)\r\n    XAxiDma_IntrDisable(&DmaInstance, XAXIDMA_IRQ_ALL_MASK, XAXIDMA_DEVICE_TO_DMA);\r\n    XAxiDma_IntrDisable(&DmaInstance, XAXIDMA_IRQ_ALL_MASK, XAXIDMA_DMA_TO_DEVICE);\r\n\r\n    print(\"Step 1: Hardware Initialization Done.\\r\\n\");\r\n\r\n    // =========================================================================\r\n    // 2. 데이터 준비 (Data Preparation)\r\n    // =========================================================================\r\n    \r\n    // 테스트용 입력 데이터 생성 (0.0, 1.0, 2.0 ...)\r\n    for(int i = 0; i < INPUT_LENGTH; i++) {\r\n        InputBuffer[i] = (float)i; \r\n    }\r\n\r\n    // 출력 버퍼 0으로 초기화\r\n    for(int i = 0; i < OUTPUT_LENGTH; i++) {\r\n        OutputBuffer[i] = 0.0f;\r\n    }\r\n\r\n    // ★ [매우 중요] CPU 캐시 플러시 (Cache Flush)\r\n    // CPU가 쓴 데이터를 실제 DDR 메모리로 밀어 넣습니다.\r\n    Xil_DCacheFlushRange((UINTPTR)InputBuffer, INPUT_SIZE_BYTES);\r\n    Xil_DCacheFlushRange((UINTPTR)OutputBuffer, OUTPUT_SIZE_BYTES);\r\n\r\n    print(\"Step 2: Input Data Prepared & Cache Flushed.\\r\\n\");\r\n\r\n    // =========================================================================\r\n    // 3. 하드웨어 실행 (Execution)\r\n    // =========================================================================\r\n    \r\n    print(\"Step 3: Starting Acceleration...\\r\\n\");\r\n\r\n    // [3-1] HLS IP 시작 (ap_start 신호 전송)\r\n    XCloud_mlp_top_Start(&HlsInstance);\r\n\r\n    // [3-2] DMA 수신(RX) 채널 시작 (FPGA -> DDR)\r\n    // 하드웨어가 뱉어낼 결과를 받을 그릇을 먼저 준비시킵니다.\r\n    Status = XAxiDma_SimpleTransfer(&DmaInstance, (UINTPTR)OutputBuffer,\r\n                                    OUTPUT_SIZE_BYTES, XAXIDMA_DEVICE_TO_DMA);\r\n    if (Status != XST_SUCCESS) {\r\n        print(\"Error: DMA RX Transfer failed.\\r\\n\");\r\n        return XST_FAILURE;\r\n    }\r\n\r\n    // [3-3] DMA 송신(TX) 채널 시작 (DDR -> FPGA)\r\n    // 입력 데이터를 하드웨어로 밀어 넣습니다.\r\n    Status = XAxiDma_SimpleTransfer(&DmaInstance, (UINTPTR)InputBuffer,\r\n                                    INPUT_SIZE_BYTES, XAXIDMA_DMA_TO_DEVICE);\r\n    if (Status != XST_SUCCESS) {\r\n        print(\"Error: DMA TX Transfer failed.\\r\\n\");\r\n        return XST_FAILURE;\r\n    }\r\n\r\n    // =========================================================================\r\n    // 4. 완료 대기 (Wait for Done)\r\n    // =========================================================================\r\n    \r\n    // DMA가 일을 다 마칠 때까지 기다립니다. (Busy가 0이 될 때까지 무한 루프)\r\n    // 만약 여기서 멈춘다면 HLS IP가 TLAST 신호를 안 보내주고 있는 것입니다.\r\n    while (XAxiDma_Busy(&DmaInstance, XAXIDMA_DMA_TO_DEVICE)) {\r\n        /* Wait for TX done */\r\n    }\r\n    while (XAxiDma_Busy(&DmaInstance, XAXIDMA_DEVICE_TO_DMA)) {\r\n        /* Wait for RX done */\r\n    }\r\n\r\n    print(\"Step 4: Hardware Computation Finished.\\r\\n\");\r\n\r\n    // =========================================================================\r\n    // 5. 결과 확인 (Result Verification)\r\n    // =========================================================================\r\n\r\n    // ★ [매우 중요] CPU 캐시 무효화 (Cache Invalidate)\r\n    // DDR에 새로 들어온 데이터를 CPU가 읽을 수 있도록 캐시를 비웁니다.\r\n    Xil_DCacheInvalidateRange((UINTPTR)OutputBuffer, OUTPUT_SIZE_BYTES);\r\n\r\n    print(\"\\r\\n--- Computation Results ---\\r\\n\");\r\n    for(int i = 0; i < OUTPUT_LENGTH; i++) {\r\n        // float 출력을 위해 정수부/소수부 분리 트릭 사용 (printf NaN 지원 안될 경우 대비)\r\n        int whole = (int)OutputBuffer[i];\r\n        int frac = (int)((OutputBuffer[i] - whole) * 1000);\r\n        if(frac < 0) frac = -frac;\r\n        \r\n        xil_printf(\"Output[%d]: %d.%03d\\r\\n\", i, whole, frac);\r\n    }\r\n    print(\"---------------------------\\r\\n\");\r\n    print(\"Successfully Done!\\r\\n\");\r\n\r\n    cleanup_platform();\r\n    return 0;\r\n}",
      "rangeOffset": 0,
      "forceMoveMarkers": false
    }
  ],
  "eol": "\r\n",
  "isEolChange": false,
  "versionId": 2,
  "isUndoing": false,
  "isRedoing": false,
  "isFlush": false
} 
