      "text": "#include \"cloud_mlp.hpp\"\r\n#include \"weights.h\"\r\n#include <cmath>\r\n\r\nfloat relu(float x) { return (x > 0) ? x : 0.0f; }\r\nfloat sigmoid(float x) {\r\n    if (x > 10.0f) return 1.0f;\r\n    if (x < -10.0f) return 0.0f;\r\n    return 1.0f / (1.0f + std::exp(-x));\r\n}\r\n\r\nvoid cloud_mlp_top(hls::stream<axis_t>& in_stream, hls::stream<axis_t>& out_stream) {\r\n    #pragma HLS INTERFACE axis port=in_stream\r\n    #pragma HLS INTERFACE axis port=out_stream\r\n    #pragma HLS INTERFACE s_axilite port=return bundle=control\r\n    #pragma HLS PIPELINE II=1\r\n\r\n    if (in_stream.empty()) return;\r\n    axis_t packet_in = in_stream.read();\r\n    ap_uint<32> data = packet_in.data;\r\n\r\n    // Unpack: [NIR:31-24][B:23-16][G:15-8][R:7-0]\r\n    uint8_t r_raw = data.range(7, 0);\r\n    uint8_t g_raw = data.range(15, 8);\r\n    uint8_t b_raw = data.range(23, 16);\r\n    uint8_t nir_raw = data.range(31, 24);\r\n\r\n    float input[4];\r\n    #pragma HLS ARRAY_PARTITION variable=input complete\r\n    input[0] = (float)r_raw / 255.0f;\r\n    input[1] = (float)g_raw / 255.0f;\r\n    input[2] = (float)b_raw / 255.0f;\r\n    input[3] = (float)nir_raw / 255.0f;\r\n\r\n    // Layer 1 (4->64)\r\n    float layer1[64];\r\n    #pragma HLS ARRAY_PARTITION variable=layer1 cyclic factor=8\r\n    for (int i = 0; i < 64; i++) {\r\n        float sum = B1[i];\r\n        for (int j = 0; j < 4; j++) sum += input[j] * W1[i][j];\r\n        layer1[i] = relu(sum);\r\n    }\r\n\r\n    // Layer 2 (64->128)\r\n    float layer2[128];\r\n    #pragma HLS ARRAY_PARTITION variable=layer2 cyclic factor=8\r\n    for (int i = 0; i < 128; i++) {\r\n        float sum = B2[i];\r\n        for (int j = 0; j < 64; j++) sum += layer1[j] * W2[i][j];\r\n        layer2[i] = relu(sum);\r\n    }\r\n\r\n    // Layer 3 (128->64)\r\n    float layer3[64];\r\n    #pragma HLS ARRAY_PARTITION variable=layer3 cyclic factor=8\r\n    for (int i = 0; i < 64; i++) {\r\n        float sum = B3[i];\r\n        for (int j = 0; j < 128; j++) sum += layer2[j] * W3[i][j];\r\n        layer3[i] = relu(sum);\r\n    }\r\n\r\n    // Output\r\n    float out_sum = B_OUT[0];\r\n    for (int j = 0; j < 64; j++) out_sum += layer3[j] * W_OUT[0][j];\r\n    \r\n    // Result Logic\r\n    uint8_t result_pixel = (sigmoid(out_sum) > 0.5f) ? 255 : 0;\r\n    \r\n    // ❄️ Snow Filter (Physical Check)\r\n    if (nir_raw < 80) result_pixel = 0;\r\n\r\n    axis_t packet_out;\r\n    packet_out.data = (result_pixel == 255) ? 0xFFFFFFFF : 0x00000000;\r\n    packet_out.keep = packet_in.keep;\r\n    packet_out.strb = packet_in.strb;\r\n    packet_out.user = packet_in.user;\r\n    packet_out.last = packet_in.last;\r\n    packet_out.id   = packet_in.id;\r\n    packet_out.dest = packet_in.dest;\r\n\r\n    out_stream.write(packet_out);\r\n}",
      "rangeOffset": 2,
      "forceMoveMarkers": false
    }
  ],
