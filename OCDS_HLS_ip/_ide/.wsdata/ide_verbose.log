      "rangeLength": 2391,
      "text": "#include \"cloud_mlp.hpp\"\r\n#include \"weights.h\"\r\n\r\n// ⚡ [최적화 1] ReLU: 분기문 최소화\r\nfloat relu(float x) {\r\n    #pragma HLS INLINE\r\n    return (x > 0.0f) ? x : 0.0f;\r\n}\r\n\r\n// ⚡ [최적화 2] Hard Sigmoid: exp와 나눗셈 제거!\r\n// y = 0.2 * x + 0.5 (하드웨어 친화적 근사)\r\nfloat hard_sigmoid(float x) {\r\n    #pragma HLS INLINE\r\n    // 기울기 0.2는 Sigmoid의 중심 기울기와 유사함\r\n    float res = 0.2f * x + 0.5f;\r\n    \r\n    // Clipping (0 ~ 1 사이로 제한)\r\n    if (res > 1.0f) return 1.0f;\r\n    if (res < 0.0f) return 0.0f;\r\n    return res;\r\n}\r\n\r\nvoid cloud_mlp_top(hls::stream<axis_t>& in_stream, hls::stream<axis_t>& out_stream) {\r\n    #pragma HLS INTERFACE axis port=in_stream\r\n    #pragma HLS INTERFACE axis port=out_stream\r\n    #pragma HLS INTERFACE s_axilite port=return bundle=control\r\n    #pragma HLS PIPELINE II=1\r\n\r\n    // 상수 미리 정의 (역수)\r\n    const float INV_255 = 0.003921568f; // 1.0 / 255.0\r\n\r\n    if (in_stream.empty()) return;\r\n    \r\n    axis_t packet_in = in_stream.read();\r\n    ap_uint<32> data = packet_in.data;\r\n\r\n    // Unpack\r\n    uint8_t r_raw = data.range(7, 0);\r\n    uint8_t g_raw = data.range(15, 8);\r\n    uint8_t b_raw = data.range(23, 16);\r\n    uint8_t nir_raw = data.range(31, 24);\r\n\r\n    // ⚡ [최적화 3] 나눗셈을 곱셈으로 변경 (/ 255.0 -> * INV_255)\r\n    float input[4];\r\n    #pragma HLS ARRAY_PARTITION variable=input complete\r\n    input[0] = (float)r_raw * INV_255;\r\n    input[1] = (float)g_raw * INV_255;\r\n    input[2] = (float)b_raw * INV_255;\r\n    input[3] = (float)nir_raw * INV_255;\r\n\r\n    // Layer 1 (4->64)\r\n    float layer1[64];\r\n    #pragma HLS ARRAY_PARTITION variable=layer1 cyclic factor=8\r\n    for (int i = 0; i < 64; i++) {\r\n        float sum = B1[i];\r\n        for (int j = 0; j < 4; j++) {\r\n            #pragma HLS UNROLL\r\n            sum += input[j] * W1[i][j];\r\n        }\r\n        layer1[i] = relu(sum);\r\n    }\r\n\r\n    // Layer 2 (64->128)\r\n    float layer2[128];\r\n    #pragma HLS ARRAY_PARTITION variable=layer2 cyclic factor=8\r\n    for (int i = 0; i < 128; i++) {\r\n        float sum = B2[i];\r\n        // 64번 루프는 길어서 파이프라인이 깨질 수 있으니 부분적으로 UNROLL\r\n        for (int j = 0; j < 64; j++) {\r\n            sum += layer1[j] * W2[i][j];\r\n        }\r\n        layer2[i] = relu(sum);\r\n    }\r\n\r\n    // Layer 3 (128->64)\r\n    float layer3[64];\r\n    #pragma HLS ARRAY_PARTITION variable=layer3 cyclic factor=8\r\n    for (int i = 0; i < 64; i++) {\r\n        float sum = B3[i];\r\n        for (int j = 0; j < 128; j++) {\r\n            sum += layer2[j] * W3[i][j];\r\n        }\r\n        layer3[i] = relu(sum);\r\n    }\r\n\r\n    // Output Layer\r\n    float out_sum = B_OUT[0];\r\n    for (int j = 0; j < 64; j++) {\r\n        out_sum += layer3[j] * W_OUT[0][j];\r\n    }\r\n    \r\n    // ⚡ [최적화 4] Hard Sigmoid 적용\r\n    uint8_t result_pixel = (hard_sigmoid(out_sum) > 0.5f) ? 255 : 0;\r\n\r\n    // Snow Filter (NIR < 80)\r\n    // 비교 연산은 하드웨어에서 매우 쌈 (LUT 몇 개면 끝)\r\n    if (nir_raw < 80) result_pixel = 0;\r\n\r\n    axis_t packet_out;\r\n    packet_out.data = (result_pixel == 255) ? 0xFFFFFFFF : 0x00000000;\r\n    packet_out.keep = packet_in.keep;\r\n    packet_out.strb = packet_in.strb;\r\n    packet_out.user = packet_in.user;\r\n    packet_out.last = packet_in.last;\r\n    packet_out.id   = packet_in.id;\r\n    packet_out.dest = packet_in.dest;\r\n\r\n    out_stream.write(packet_out);\r\n}",
      "rangeOffset": 0,
      "forceMoveMarkers": false
    }
  ],
